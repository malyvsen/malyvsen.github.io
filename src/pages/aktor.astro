---
import Base from "@/layouts/Base.astro";
import faceCutout from "@/assets/face-cutout.png";
---

<Base title="Mikołaj Bocheński" description="Aktor">
  <div class="container">
    <div class="text-area mobile-only">
      <h1>Mikołaj Bocheński</h1>
      <p class="bio">
        Cześć! Jestem 27-letnim aktorem z Krakowa. Mam doświadczenie przed kamerą
        i na scenie, również muzycznej. Gram w teatrze Loch Camelot. Mówię z
        dobrym akcentem po polsku, angielsku (dzieciństwo spędziłem w Kalifornii),
        niemiecku, holendersku, szwedzku i włosku. Skończyłem roczne studium
        aktorstwa filmowego na Mulholland Academy w Amsterdamie, a obecnie trwa
        trzeci rok mojej edukacji w Szkole Wokalno-Aktorskiej w Krakowie.
      </p>
    </div>
    <div class="bottom-section mobile-only">
      <img class="face-cutout" src={faceCutout.src} alt="Mikołaj Bocheński" />
      <div class="spacer"></div>
      <div class="links">
        <p class="links-text">
          <a href="https://www.instagram.com/malyvsen/">Instagram</a><br />
          <a href="https://photos.app.goo.gl/yFrqRuZ5tNMAWF5MA">Galeria zdjęć</a><br />
          <a href="https://www.youtube.com/watch?v=DupTZI6PZTQ">Demo filmowe</a>
        </p>
      </div>
    </div>
    <div class="desktop-layout desktop-only">
      <div class="face-container">
        <img class="face-cutout-desktop" src={faceCutout.src} alt="Mikołaj Bocheński" />
      </div>
      <div class="content-area">
        <h1>Mikołaj Bocheński</h1>
        <p class="bio">
          Cześć! Jestem 27-letnim aktorem z Krakowa. Mam doświadczenie przed kamerą
          i na scenie, również muzycznej. Gram w teatrze Loch Camelot. Mówię z
          dobrym akcentem po polsku, angielsku (dzieciństwo spędziłem w Kalifornii),
          niemiecku, holendersku, szwedzku i włosku. Skończyłem roczne studium
          aktorstwa filmowego na Mulholland Academy w Amsterdamie, a obecnie trwa
          trzeci rok mojej edukacji w Szkole Wokalno-Aktorskiej w Krakowie.
        </p>
        <div class="links-desktop">
          <p class="links-text">
            <a href="https://www.instagram.com/malyvsen/">Instagram</a><br />
            <a href="https://photos.app.goo.gl/yFrqRuZ5tNMAWF5MA">Galeria zdjęć</a><br />
            <a href="https://www.youtube.com/watch?v=DupTZI6PZTQ">Demo filmowe</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .container {
    min-height: 100vh;
    background-color: #ece0d7;
  }

  .mobile-only {
    display: flex;
  }

  .desktop-only {
    display: none;
  }

  .text-area {
    flex-direction: column;
    margin-left: 2em;
    margin-right: 2em;
  }

  .bio {
    font-size: 1.4em;
    text-align: justify;
  }

  .bottom-section {
    width: 100%;
  }

  .face-cutout {
    width: 60%;
    margin-top: -9%;
    margin-right: -10%;
    object-fit: contain;
    vertical-align: top;
  }

  .spacer {
    width: 2em;
  }

  .links {
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin-right: 2em;
  }

  .links-text {
    font-size: 1.4em;
  }

  @media (min-width: 900px) {
    .mobile-only {
      display: none;
    }

    .desktop-only {
      display: flex;
    }

    .desktop-layout {
      flex-direction: row;
      justify-content: start;
      min-height: 100vh;
    }

    .face-container {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: start;
      align-self: end;
      max-width: 40%;
      height: 100%;
    }

    .face-cutout-desktop {
      max-width: 100%;
      max-height: 95vh;
      margin-top: -9%;
      margin-right: -10%;
      object-fit: contain;
      vertical-align: top;
    }

    .content-area {
      width: 75%;
      max-width: 50em;
      margin-right: 2em;
      align-self: center;
    }

    .links-desktop {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
  }
</style>
